# Optional. Required only for WalletConnect QR/deep-link pairing.
# Create your own project at https://dashboard.walletconnect.com/
NEXT_PUBLIC_WC_PROJECT_ID=

# Optional. Leave empty to let zera.js use its built-in mainnet endpoint.
NEXT_PUBLIC_ZERA_GRPC_ENDPOINT=

# Optional. Generic ZERA wallet scheme used by the adapter outside an injected wallet browser.
NEXT_PUBLIC_ZERA_DEEPLINK_URL=zera-wallet://
